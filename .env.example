# ─── Database ────────────────────────────────────────────────────────────────
# NOTE: If your password contains @ or special chars, percent-encode them:
#   @ → %40   # → %23   : → %3A
# Example: password "Mustafa@1122" → "Mustafa%401122"
DATABASE_URL=postgresql+asyncpg://postgres:Mustafa%401122@localhost:5432/easypay

# ─── Security ────────────────────────────────────────────────────────────────
# SECRET_KEY: 64-char hex  →  openssl rand -hex 32
# ENCRYPTION_KEY: Fernet key  →  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ADMIN_SECRET_HEADER: 32-char random  →  openssl rand -hex 16
SECRET_KEY=
ENCRYPTION_KEY=
ADMIN_SECRET_HEADER=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_EXPIRY_HOURS=
ADMIN_JWT_EXPIRY_HOURS=
REFRESH_TOKEN_EXPIRY_DAYS=

# ─── OTP & Pending Transactions ──────────────────────────────────────────────
OTP_EXPIRY_MINUTES=
PENDING_TX_TOKEN_EXPIRY_SECONDS=

# ─── Admin Seed (Point 17) ───────────────────────────────────────────────────
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ─── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase FCM ────────────────────────────────────────────────────────────
# FCM_SERVICE_ACCOUNT_JSON: single-line JSON string from Firebase console (Point 7)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# ─── DeepSeek AI ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# ─── Stripe (Card Top-Up) ────────────────────────────────────────────────────
# Get your test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Business Verification Thresholds ────────────────────────────────────────
BUSINESS_AI_AUTO_APPROVE_THRESHOLD=
BUSINESS_AI_MANUAL_REVIEW_THRESHOLD=

# ─── Fraud Detection Thresholds (Point 19) ───────────────────────────────────
FRAUD_HIGH_TX_AMOUNT=
FRAUD_VELOCITY_COUNT=
FRAUD_VELOCITY_MINUTES=
FRAUD_NEW_ACCOUNT_HOURS=
FRAUD_NEW_ACCOUNT_AMOUNT=

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=
ALLOWED_ORIGINS=
